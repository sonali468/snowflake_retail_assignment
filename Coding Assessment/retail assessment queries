// SNOWFLAKE SETUP 

CREATE OR REPLACE DATABASE RETAIL_DB;

CREATE OR REPLACE SCHEMA RETAIL_DB.ORDERS_DEMO;

CREATE OR REPLACE WAREHOUSE RETAIL_LOAD_WH
WITH
WAREHOUSE_SIZE = 'XSMALL'
AUTO_SUSPEND = 60
AUTO_RESUME = TRUE;

CREATE OR REPLACE ROLE RETAIL_DATA_ENGINEER_ROLE;

CREATE OR REPLACE USER RETAIL_ENGINEER_USER
PASSWORD = 'Retail@12345'
FIRST_NAME = 'Retail'
LAST_NAME = 'Engineer_User'
DEFAULT_ROLE = RETAIL_DATA_ENGINEER_ROLE
DEFAULT_WAREHOUSE = RETAIL_LOAD_WH
MUST_CHANGE_PASSWORD = FALSE;


GRANT ROLE RETAIL_DATA_ENGINEER_ROLE TO USER RETAIL_ENGINEER_USER;

GRANT USAGE ON WAREHOUSE RETAIL_LOAD_WH TO ROLE RETAIL_DATA_ENGINEER_ROLE;
GRANT USAGE ON DATABASE RETAIL_DB TO ROLE RETAIL_DATA_ENGINEER_ROLE;
GRANT USAGE ON SCHEMA RETAIL_DB.ORDERS_DEMO TO ROLE RETAIL_DATA_ENGINEER_ROLE;

GRANT CREATE TABLE, CREATE STAGE, CREATE FILE FORMAT, CREATE PIPE 
ON SCHEMA RETAIL_DB.ORDERS_DEMO TO ROLE RETAIL_DATA_ENGINEER_ROLE;


// SNOWFLAKE EXTERNAL STAGE

CREATE OR REPLACE FILE FORMAT RETAIL_DB.ORDERS_DEMO.FILE_FORMAT_CSV
TYPE= 'CSV'
FIELD_DELIMITER = ','
SKIP_HEADER = 1;

CREATE OR REPLACE STAGE RETAIL_DB.ORDERS_DEMO.RETAIL_ORDERS_STAGE
url = 'azure://retailstorageadlssonali.blob.core.windows.net/retail-data/raw/orders/'
CREDENTIALS = (
    AZURE_SAS_TOKEN = 'sv=2026-02-06&ss=bfqt&srt=sco&sp=rwdlacupyx&se=2026-05-22T14:28:18Z&st=2026-05-21T12:28:18Z&spr=https&sig=d16WMhq7eLuRZjJ9w8po%2FqgP%2FlqwYzsyyCn%2BD2ctzm8%3D'
)
FILE_FORMAT = RETAIL_DB.ORDERS_DEMO.FILE_FORMAT_CSV;

LIST @RETAIL_DB.ORDERS_DEMO.RETAIL_ORDERS_STAGE;


// INITIAL DATA LOAD

CREATE OR REPLACE TABLE RETAIL_DB.ORDERS_DEMO.ORDERS_RAW (
    ORDER_ID INT,
    PRODUCT_ID STRING,
    PRODUCT_NAME STRING,
    QUANTITY INT,
    PRICE NUMBER(10,2),
    ORDER_DATE DATE
);

CREATE OR REPLACE TABLE RETAIL_DB.ORDERS_DEMO.ORDERS_FINAL (
    ORDER_ID INT,
    PRODUCT_ID STRING,
    PRODUCT_NAME STRING,
    QUANTITY INT,
    PRICE NUMBER(10,2),
    ORDER_DATE DATE
);


COPY INTO RETAIL_DB.ORDERS_DEMO.ORDERS_RAW (
    ORDER_ID, PRODUCT_ID, PRODUCT_NAME, QUANTITY, PRICE, ORDER_DATE
)
FROM (
    SELECT $1::INT,
           $12:: STRING,
           $11::STRING,
           $15::INT,
           $14::NUMBER(10,2),
           $2::DATE
    FROM @RETAIL_DB.ORDERS_DEMO.RETAIL_ORDERS_STAGE
)
FILE_FORMAT = RETAIL_DB.ORDERS_DEMO.FILE_FORMAT_CSV
files = ('retail_orders_initial.csv');

SELECT * FROM RETAIL_DB.ORDERS_DEMO.ORDERS_RAW;

INSERT INTO RETAIL_DB.ORDERS_DEMO.ORDERS_FINAL
SELECT * FROM RETAIL_DB.ORDERS_DEMO.ORDERS_RAW;

SELECT * FROM RETAIL_DB.ORDERS_DEMO.ORDERS_FINAL;


// INCREMENTAL LOADING

//SNOWPIPE IMPLEMENTATION 

CREATE OR REPLACE PIPE RETAIL_DB.ORDERS_DEMO.RETAIL_ORDERS_PIPE
AS
COPY INTO RETAIL_DB.ORDERS_DEMO.ORDERS_RAW(
    ORDER_ID,PRODUCT_ID,PRODUCT_NAME,QUANTITY,PRICE,ORDER_DATE)
FROM (
    SELECT
        $1::INT,
        $12::STRING,
        $11::STRING,
        $15::INT,
        $14::NUMBER(10,2),
        $2::DATE
    FROM @RETAIL_DB.ORDERS_DEMO.RETAIL_ORDERS_STAGE
)
FILE_FORMAT = RETAIL_DB.ORDERS_DEMO.FILE_FORMAT_CSV;

ALTER PIPE RETAIL_DB.ORDERS_DEMO.RETAIL_ORDERS_PIPE REFRESH;

SELECT * FROM RETAIL_DB.ORDERS_DEMO.ORDERS_RAW;


CREATE OR REPLACE STREAM RETAIL_DB.ORDERS_DEMO.ORDERS_RAW_STREAM
ON TABLE RETAIL_DB.ORDERS_DEMO.ORDERS_RAW;

SELECT * FROM RETAIL_DB.ORDERS_DEMO.ORDERS_RAW_STREAM;


CREATE OR REPLACE TASK RETAIL_DB.ORDERS_DEMO.ORDERS_MERGE_TASK
WAREHOUSE = RETAIL_LOAD_WH
SCHEDULE = '1 MINUTE'
AS
MERGE INTO RETAIL_DB.ORDERS_DEMO.ORDERS_FINAL F
USING (
    SELECT ORDER_ID, PRODUCT_ID, PRODUCT_NAME, QUANTITY, PRICE, ORDER_DATE
    FROM RETAIL_DB.ORDERS_DEMO.ORDERS_RAW_STREAM
    WHERE METADATA$ACTION = 'INSERT'
) S
ON F.ORDER_ID = S.ORDER_ID
WHEN NOT MATCHED THEN
INSERT (ORDER_ID,PRODUCT_ID,PRODUCT_NAME,QUANTITY,PRICE,ORDER_DATE)
VALUES 
(S.ORDER_ID,S.PRODUCT_ID,S.PRODUCT_NAME,S.QUANTITY,S.PRICE,S.ORDER_DATE);

ALTER TASK RETAIL_DB.ORDERS_DEMO.ORDERS_MERGE_TASK RESUME;

SELECT * FROM RETAIL_DB.ORDERS_DEMO.ORDERS_FINAL;



//AFTER UPLOADING NEW INCREMENTAL DATA 
ALTER PIPE RETAIL_DB.ORDERS_DEMO.RETAIL_ORDERS_PIPE REFRESH;

EXECUTE TASK RETAIL_DB.ORDERS_DEMO.ORDERS_MERGE_TASK;

SELECT * FROM RETAIL_DB.ORDERS_DEMO.ORDERS_FINAL;



// CLEAN UP
ALTER TASK RETAIL_DB.ORDERS_DEMO.ORDERS_MERGE_TASK SUSPEND;
drop database retail_db;
DROP WAREHOUSE RETAIL_LOAD_WH;
DROP ROLE RETAIL_DATA_ENGINEER_ROLE;
DROP USER RETAIL_ENGINEER_USER;

ALTER TASK RETAIL_DB.ORDERS_DEMO.ORDERS_MERGE_TASK RESUME;
